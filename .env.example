# ===========================================
# Evolution API - Environment Configuration
# ===========================================
# Only variables that REQUIRE user-specific values are listed here.
# All other settings have sensible defaults in src/config/env.config.ts.
# Override any default by adding the corresponding env var here.

# Database connection (required)
DATABASE_CONNECTION_URI='postgresql://user:pass@localhost:5432/evolution_db?schema=evolution_api'

# Global API key for authentication (required)
AUTHENTICATION_API_KEY=YOUR_SUPER_SECRET_KEY_HERE

# Redis cache
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://localhost:6379/6
